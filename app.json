{
  "expo": {
    "name": "Price Timer",
    "slug": "price-timer",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "sdkVersion": "54.0.0",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Price Timer usa a câmera para detectar preços ao vivo."
        }
      ]
    ],
    "scheme": "price-timer",
    "experiments": {
      "typedRoutes": true
    }
  }
}
